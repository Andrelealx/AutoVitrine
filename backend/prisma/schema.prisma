generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  STORE_OWNER
  STORE_STAFF
}

enum VehicleStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum FuelType {
  FLEX
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  AUTOMATED
}

enum ThemeMode {
  LIGHT
  DARK
  LUXURY
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                UserRole  @default(STORE_OWNER)
  isActive            Boolean   @default(true)
  storeId             String?
  store               Store?    @relation("StoreUsers", fields: [storeId], references: [id], onDelete: SetNull)
  ownedStore          Store?    @relation("StoreOwner")
  refreshTokenHash    String?
  resetToken          String?
  resetTokenExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Store {
  id                 String          @id @default(cuid())
  ownerId            String          @unique
  owner              User            @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name               String          @default("Minha Loja")
  slug               String          @unique
  logoUrl            String?
  bannerUrl          String?
  primaryColor       String          @default("#C9A44C")
  secondaryColor     String          @default("#111111")
  theme              ThemeMode       @default(LUXURY)
  city               String?
  state              String?
  whatsapp           String?
  instagram          String?
  facebook           String?
  description        String?
  slogan             String?
  aboutUs            String?
  openingHours       String?
  address            String?
  mapEmbedUrl        String?
  isActive           Boolean         @default(true)
  onboardingCompleted Boolean        @default(false)
  users              User[]          @relation("StoreUsers")
  vehicles           Vehicle[]
  leads              Lead[]
  subscriptions      Subscription[]
  storefrontViews    StorefrontView[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Vehicle {
  id            String           @id @default(cuid())
  storeId       String
  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  brand         String
  model         String
  year          Int
  color         String
  mileage       Int
  fuel          FuelType
  transmission  TransmissionType
  price         Decimal          @db.Decimal(12, 2)
  description   String
  optionalItems String[]
  status        VehicleStatus    @default(AVAILABLE)
  featured      Boolean          @default(false)
  images        VehicleImage[]
  leads         Lead[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([storeId, status])
  @@index([storeId, brand, year])
}

model VehicleImage {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  name      String
  phone     String
  email     String?
  message   String
  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
}

model Plan {
  id           String         @id @default(cuid())
  name         String         @unique
  description  String
  priceCents   Int
  vehicleLimit Int?
  userLimit    Int?
  stripePriceId String?       @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                  String             @id @default(cuid())
  storeId             String             @unique
  store               Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  stripeCustomerId    String?
  stripeSubscriptionId String?           @unique
  status              SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model StorefrontView {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessionId String
  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@unique([storeId, sessionId])
}