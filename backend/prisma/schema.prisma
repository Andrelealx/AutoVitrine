generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  STORE_OWNER
  STORE_STAFF
}

enum VehicleStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum FuelType {
  FLEX
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  AUTOMATED
}

enum ThemeMode {
  LIGHT
  DARK
  LUXURY
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum BillingGateway {
  STRIPE
  MERCADO_PAGO
  TRIAL
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  CANCELED
  REFUNDED
}

enum StoreSuspensionReason {
  MANUAL
  PAYMENT_FAILED
  CANCELED
  TRIAL_EXPIRED
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                UserRole  @default(STORE_OWNER)
  isActive            Boolean   @default(true)
  storeId             String?
  store               Store?    @relation("StoreUsers", fields: [storeId], references: [id], onDelete: SetNull)
  ownedStore          Store?    @relation("StoreOwner")
  refreshTokenHash    String?
  resetToken          String?
  resetTokenExpiresAt DateTime?
  auditLogs           AuditLog[] @relation("AuditActor")
  impersonationLogs   AuditLog[] @relation("AuditImpersonator")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Store {
  id                 String          @id @default(cuid())
  ownerId            String          @unique
  owner              User            @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name               String          @default("Minha Loja")
  slug               String          @unique
  logoUrl            String?
  bannerUrl          String?
  primaryColor       String          @default("#C9A44C")
  secondaryColor     String          @default("#111111")
  theme              ThemeMode       @default(LUXURY)
  city               String?
  state              String?
  whatsapp           String?
  instagram          String?
  facebook           String?
  description        String?
  slogan             String?
  aboutUs            String?
  openingHours       String?
  address            String?
  customDomain       String?          @unique
  mapEmbedUrl        String?
  isActive           Boolean         @default(true)
  suspendedAt        DateTime?
  suspensionReason   StoreSuspensionReason?
  suspensionNote     String?
  unavailableMessage String?
  dataRetentionUntil DateTime?
  outboundWebhookUrl String?
  outboundWebhookSecret String?
  onboardingCompleted Boolean        @default(false)
  users              User[]          @relation("StoreUsers")
  vehicles           Vehicle[]
  leads              Lead[]
  subscriptions      Subscription[]
  payments           Payment[]
  auditLogs          AuditLog[]
  storefrontViews    StorefrontView[]
  lojaFiscal         LojaFiscal?
  notasFiscais       NotaFiscal[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Vehicle {
  id            String           @id @default(cuid())
  storeId       String
  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  brand         String
  model         String
  year          Int
  color         String
  mileage       Int
  fuel          FuelType
  transmission  TransmissionType
  price         Decimal          @db.Decimal(12, 2)
  description   String
  optionalItems String[]
  status        VehicleStatus    @default(AVAILABLE)
  featured      Boolean          @default(false)
  plate         String?
  renavam       String?
  chassis       String?
  images        VehicleImage[]
  leads         Lead[]
  notasFiscais  NotaFiscal[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([storeId, status])
  @@index([storeId, brand, year])
}

model VehicleImage {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  name      String
  phone     String
  email     String?
  message   String
  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
}

model Plan {
  id                    String         @id @default(cuid())
  name                  String         @unique
  description           String
  priceCents            Int
  vehicleLimit          Int?
  userLimit             Int?
  maxPhotosPerVehicle   Int?
  allowCustomDomain     Boolean        @default(false)
  removeWatermark       Boolean        @default(false)
  includeReports        Boolean        @default(false)
  includeAdvancedReports Boolean       @default(false)
  allowOutboundWebhooks Boolean        @default(false)
  trialDays             Int?
  isTrial               Boolean        @default(false)
  showTrialBanner       Boolean        @default(false)
  isActive              Boolean        @default(true)
  sortOrder             Int            @default(0)
  stripePriceId         String?        @unique
  mercadopagoPlanId     String?        @unique
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  subscriptions         Subscription[]
}

model Subscription {
  id                       String             @id @default(cuid())
  storeId                  String             @unique
  store                    Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  planId                   String
  plan                     Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  gateway                  BillingGateway?
  stripeCustomerId         String?
  stripeSubscriptionId     String?            @unique
  mercadopagoSubscriptionId String?           @unique
  mercadopagoPreferenceId  String?
  mercadopagoPayerId       String?
  status                   SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd         DateTime?
  trialEndsAt              DateTime?
  gracePeriodEndsAt        DateTime?
  suspendedAt              DateTime?
  dataRetentionUntil       DateTime?
  canceledAt               DateTime?
  cancellationReason       String?
  activatedAt              DateTime?
  lastPaymentAt            DateTime?
  failedPaymentAt          DateTime?
  paymentFailureCount      Int                @default(0)
  welcomeEmailSentAt       DateTime?
  dueReminderSentAt        DateTime?
  trialReminderSentAt      DateTime?
  failureEmailSentAt       DateTime?
  suspensionEmailSentAt    DateTime?
  reactivationEmailSentAt  DateTime?
  cancelAtPeriodEnd        Boolean            @default(false)
  payments                 Payment[]
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([status, currentPeriodEnd])
  @@index([gracePeriodEndsAt])
}

model Payment {
  id                    String         @id @default(cuid())
  storeId               String
  store                 Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  subscriptionId        String?
  subscription          Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  gateway               BillingGateway
  status                PaymentStatus  @default(PENDING)
  amountCents           Int
  currency              String         @default("BRL")
  paymentMethod         String?
  externalPaymentId     String?        @unique
  externalReference     String?
  externalPreferenceId  String?
  externalSubscriptionId String?
  paidAt                DateTime?
  dueAt                 DateTime?
  failureReason         String?
  payload               Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([storeId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([externalReference])
}

model AuditLog {
  id                   String    @id @default(cuid())
  action               String
  entityType           String
  entityId             String?
  description          String?
  metadata             Json?
  actorUserId          String?
  actorUser            User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail           String?
  actorRole            UserRole?
  impersonatedByUserId String?
  impersonatedByUser   User?     @relation("AuditImpersonator", fields: [impersonatedByUserId], references: [id], onDelete: SetNull)
  storeId              String?
  store                Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime  @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([storeId, createdAt])
}

model StorefrontView {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessionId String
  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@unique([storeId, sessionId])
}

model LojaFiscal {
  id               String   @id @default(cuid())
  lojaId           String   @unique
  loja             Store    @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  cnpj             String
  ie               String
  crt              Int      @default(1)
  certificadoPfx   Bytes?
  certificadoSenha String?
  ambiente         Int      @default(2)
  serie            Int      @default(1)
  ultimaNNF        Int      @default(0)
  logradouro       String   @default("")
  numero           String   @default("")
  bairro           String   @default("")
  cMun             String   @default("")
  xMun             String   @default("")
  uf               String   @default("")
  cep              String   @default("")
  fone             String   @default("")
  cUF              Int      @default(33)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model NotaFiscal {
  id                  String    @id @default(cuid())
  lojaId              String
  loja                Store     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  veiculoId           String?
  veiculo             Vehicle?  @relation(fields: [veiculoId], references: [id], onDelete: SetNull)
  chaveAcesso         String    @unique
  nNF                 Int
  serie               Int
  dhEmi               DateTime
  nomeDestinatario    String
  cpfCnpjDestinatario String
  emailDestinatario   String?
  valorTotal          Float
  renavam             String?
  chassi              String?
  xmlEnviado          String    @db.Text
  xmlAutorizado       String?   @db.Text
  protocolo           String?
  status              String    @default("pendente")
  motivoErro          String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([lojaId, createdAt])
  @@index([lojaId, status])
}
